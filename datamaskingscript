-- FAKE PHONE NUMBER
-- Generates Egyptian-style 11-digit phone numbers starting with 010, 011, 012, or 015
--------------------------------------------------------------------------------
CREATE OR REPLACE PROCEDURE fake_phone(
  p_table_name IN VARCHAR2,
  p_column     IN VARCHAR2 DEFAULT 'phone_number'
) IS
BEGIN
  EXECUTE IMMEDIATE
    'UPDATE '||p_table_name|| 
    ' SET '||p_column||' = 
        CASE TRUNC(DBMS_RANDOM.VALUE(1,5))
          WHEN 1 THEN ''010''
          WHEN 2 THEN ''011''
          WHEN 3 THEN ''012''
          ELSE ''015''
        END
        || TO_CHAR(TRUNC(DBMS_RANDOM.VALUE(10000000,99999999)))';
  -- Ensures total length = 11 digits
  COMMIT;
END;
/

