CREATE OR REPLACE PROCEDURE fake_name(

  p_table_name IN VARCHAR2,

  p_column     IN VARCHAR2 DEFAULT 'name'

) IS

  TYPE rid_tab_t IS TABLE OF ROWID;

  v_rids rid_tab_t;

  v1     VARCHAR2(100);

  v2     VARCHAR2(100);

  v3     VARCHAR2(100);

BEGIN

  EXECUTE IMMEDIATE

    'SELECT ROWID FROM '||p_table_name

    BULK COLLECT INTO v_rids;

 

  FOR i IN 1..v_rids.COUNT LOOP

    SELECT name INTO v1 FROM (SELECT name FROM names ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM=1;

    SELECT name INTO v2 FROM (SELECT name FROM names ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM=1;

    SELECT name INTO v3 FROM (SELECT name FROM names ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM=1;

 

    EXECUTE IMMEDIATE

      'UPDATE '||p_table_name||

      ' SET '||p_column||' = :1 WHERE ROWID = :2'

      USING (v1||' '||v2||' '||v3), v_rids(i);

  END LOOP;

 

  COMMIT;

END;

/


 

CREATE OR REPLACE PROCEDURE fake_address(

  p_table_name IN VARCHAR2,

  p_column     IN VARCHAR2 DEFAULT 'address'

) IS

  TYPE rid_tab_t IS TABLE OF ROWID;

  v_rids rid_tab_t;

  v_no   VARCHAR2(10);

  v_st   VARCHAR2(100);

  v_ct   VARCHAR2(100);

BEGIN

  EXECUTE IMMEDIATE

    'SELECT ROWID FROM '||p_table_name

    BULK COLLECT INTO v_rids;

 

  FOR i IN 1..v_rids.COUNT LOOP

    SELECT street_no INTO v_no FROM (SELECT street_no FROM street_numbers ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM=1;

    SELECT name      INTO v_st FROM (SELECT name      FROM street_names   ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM=1;

    SELECT city      INTO v_ct FROM (SELECT city      FROM cities         ORDER BY DBMS_RANDOM.VALUE) WHERE ROWNUM=1;

 

    EXECUTE IMMEDIATE

      'UPDATE '||p_table_name||

      ' SET '||p_column||' = :1 WHERE ROWID = :2'

      USING (v_no||' '||v_st||', '||v_ct), v_rids(i);

  END LOOP;

 

  COMMIT;

END;

/


 

CREATE OR REPLACE PROCEDURE fake_national_id(

  p_table_name IN VARCHAR2,

  p_column     IN VARCHAR2 DEFAULT 'national_id'

) IS

  TYPE rid_tab_t IS TABLE OF ROWID;

  v_rids rid_tab_t;

  v_nid  VARCHAR2(14);

BEGIN

  EXECUTE IMMEDIATE

    'SELECT ROWID FROM '||p_table_name

    BULK COLLECT INTO v_rids;

 

  FOR i IN 1..v_rids.COUNT LOOP

    v_nid := CASE WHEN TO_CHAR(SYSDATE,'YYYY') >= '2000' THEN '3' ELSE '2' END

          || TO_CHAR(TRUNC(DBMS_RANDOM.VALUE(0,100)),'FM00')

          || TO_CHAR(TRUNC(DBMS_RANDOM.VALUE(1,13)),'FM00')

          || TO_CHAR(TRUNC(DBMS_RANDOM.VALUE(1,29)),'FM00')

          || TO_CHAR(TRUNC(DBMS_RANDOM.VALUE(1,30)),'FM00')

          || TO_CHAR(TRUNC(DBMS_RANDOM.VALUE(0,10000)),'FM0000')

          || TO_CHAR(TRUNC(DBMS_RANDOM.VALUE(0,10)),'FM0');

 

    EXECUTE IMMEDIATE

      'UPDATE '||p_table_name||

      ' SET '||p_column||' = :1 WHERE ROWID = :2'

      USING v_nid, v_rids(i);

  END LOOP;

 

  COMMIT;

END;

/


 

CREATE OR REPLACE PROCEDURE scramble_swap(

  p_table_name IN VARCHAR2,

  p_column     IN VARCHAR2 DEFAULT 'account_number',

  p1           IN PLS_INTEGER,

  p2           IN PLS_INTEGER

) AS

BEGIN

  EXECUTE IMMEDIATE

    'UPDATE '||p_table_name||

    ' SET '||p_column||'= swap_digits('||p_column||','||p1||','||p2||')';

  COMMIT;

END;

/


 

CREATE OR REPLACE PROCEDURE scramble_mod(

  p_table_name IN VARCHAR2,

  p_column     IN VARCHAR2 DEFAULT 'account_number',

  p1           IN PLS_INTEGER,

  p2           IN PLS_INTEGER

) AS

BEGIN

  EXECUTE IMMEDIATE

    'UPDATE '||p_table_name||

    ' SET '||p_column||'= mod_digits('||p_column||','||p1||','||p2||')';

  COMMIT;

END;

/



 

CREATE OR REPLACE PROCEDURE mask_card(

  p_table_name IN VARCHAR2,

  p_column     IN VARCHAR2 DEFAULT 'card_number'

) AS

BEGIN

  EXECUTE IMMEDIATE

    'UPDATE '||p_table_name||

    ' SET '||p_column||'= mask_card_number('||p_column||')';

  COMMIT;

END;

/



