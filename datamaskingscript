CREATE OR REPLACE FUNCTION mask_card_number(p_card VARCHAR2) 
RETURN VARCHAR2 IS
BEGIN
  RETURN SUBSTR(p_card,1,4)
         || RPAD('*', GREATEST(LENGTH(p_card)-8,0), '*')
         || SUBSTR(p_card,-4);
END;
/


CREATE OR REPLACE FUNCTION swap_digits(

  p_in VARCHAR2,

  p1   PLS_INTEGER,

  p2   PLS_INTEGER

) RETURN VARCHAR2 IS

  v_out VARCHAR2(32767) := p_in;

  c1    CHAR(1);

  c2    CHAR(1);

BEGIN

  IF LENGTH(p_in) < GREATEST(p1,p2) THEN

    RETURN p_in;

  END IF;

  c1 := SUBSTR(p_in,p1,1);

  c2 := SUBSTR(p_in,p2,1);

  v_out := SUBSTR(v_out,1,p1-1)||c2||SUBSTR(v_out,p1+1);

  v_out := SUBSTR(v_out,1,p2-1)||c1||SUBSTR(v_out,p2+1);

  RETURN v_out;

END;

/


 

CREATE OR REPLACE FUNCTION mod_digits(

  p_in VARCHAR2,

  p1   PLS_INTEGER,

  p2   PLS_INTEGER

) RETURN VARCHAR2 IS

  d1    NUMBER := TO_NUMBER(SUBSTR(p_in,p1,1));

  d2    NUMBER := TO_NUMBER(SUBSTR(p_in,p2,1));

  v_sum PLS_INTEGER := MOD(d1+d2,8);

  v_out VARCHAR2(32767) := p_in;

BEGIN

  IF LENGTH(p_in) < GREATEST(p1,p2) THEN

    RETURN p_in;

  END IF;

  v_out := SUBSTR(v_out,1,p1-1)

       || TO_CHAR(v_sum)

       || SUBSTR(v_out,p1+1);

  RETURN v_out;

END;

/


 

