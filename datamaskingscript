-- FAKE EMAIL BASED ON RANDOM NAMES (from lookup table "names")
--------------------------------------------------------------------------------
CREATE OR REPLACE PROCEDURE fake_email(
    p_table_name   IN VARCHAR2,
    p_column       IN VARCHAR2
) IS
    TYPE rid_tab_t IS TABLE OF ROWID;
    v_rids   rid_tab_t;
    v_name   NVARCHAR2(100);
BEGIN
    -- Collect all rowids of the target table
    EXECUTE IMMEDIATE
        'SELECT ROWID FROM ' || p_table_name
        BULK COLLECT INTO v_rids;

    -- Loop through each row and assign a fake email
    FOR i IN 1..v_rids.COUNT LOOP
        -- Pick a random name from names lookup table
        SELECT name
        INTO v_name
        FROM (
            SELECT name FROM names ORDER BY DBMS_RANDOM.VALUE
        )
        WHERE ROWNUM = 1;

        -- Update the row with a generated email
        EXECUTE IMMEDIATE
            'UPDATE ' || p_table_name ||
            ' SET ' || p_column || ' = :1 WHERE ROWID = :2'
        USING LOWER(v_name) || TRUNC(DBMS_RANDOM.VALUE(100,9999)) || '@gmail.com', v_rids(i);
    END LOOP;

    COMMIT;
END;
/

